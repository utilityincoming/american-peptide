# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# GSC reports + service-account keys (never commit query data or credentials)
/reports/
*gsc-sa*.json

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# TWA / Bubblewrap Android wrapper (generated + secrets)
# Keep only twa-manifest.json under version control; everything else is
# regenerated by `bubblewrap update` (or scripts/gen-project) from it.
/twa/*
!/twa/twa-manifest.json
# never commit signing material under any circumstances
*.keystore
*.jks
KEYSTORE_SECRETS.md
