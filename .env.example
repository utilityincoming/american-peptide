# Copy this file to .env.local and fill in real values.
# Never commit .env.local to version control.

# Anthropic API key — required for the /api/chat research agent endpoint.
# Get yours at https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Waitlist (/api/waitlist) — Resend ────────────────────────────────────────
# All optional: without RESEND_API_KEY the endpoint logs signups and still
# returns success, so dev works with no setup.
#
# API key from https://resend.com/api-keys
RESEND_API_KEY=
# Default audience (https://resend.com/audiences) every signup is added to.
RESEND_AUDIENCE_ID=
# Optional: supplier signups go to this audience instead, if set.
RESEND_AUDIENCE_SUPPLIER_ID=
# From address for the confirmation email. Domain must be verified in Resend.
# e.g. "AmericanPeptide <waitlist@americanpeptide.com>"
RESEND_FROM=
# Optional: internal address that receives a full-detail signup notification
# (preserves role + source, which Resend audiences don't store).
WAITLIST_NOTIFY=
